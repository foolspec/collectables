+	}
+	auto &settings = AyuSettings::getInstance();
+	return rpl::combine(
+		settings.localProfileGiftEnabledValue(),
+		settings.localProfileGiftValue(),
+		settings.localProfileGiftsValue()
+	) | rpl::map([](
+			bool enabled,
+			QString featured,
+			QString gifts) {
