+				  [=](bool value) { state->readReminder = value; });
+		addToggle(tr::ayu_VaultPrivateDraftValue(), existing.privateDraft,
+				  [=](bool value) { state->privateDraft = value; });
+		addToggle(tr::ayu_VaultLocalMuteValue(), existing.localMute,
