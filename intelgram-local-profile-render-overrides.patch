+		return realAbout;
+	}
+	if (const auto clone = ResolveLocalProfileCloneUser(peer)) {
+		return clone->about();
+	}
+	if (!enabled) {
+		return realAbout;
+	}
+	localAbout = NormalizeLocalProfileAbout(std::move(localAbout));
+	return localAbout.isEmpty() ? realAbout : localAbout;
+}
